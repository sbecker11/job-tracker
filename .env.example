# Copy this file to `.env` (same directory) and fill in real values.
# `.env` is git-ignored and loaded automatically at startup via python-dotenv.

# Required only if you run the pipeline with --llm-fallback.
# Used to extract (company, title) pairs from job digest emails that the
# rule-based parsers in pipeline/extract.py can't confidently handle.
# Get a key at https://console.anthropic.com/settings/keys
#
# As of 2026-07-15 this can also come from the shared
# workspace-recruiting-automation/.env one level up (single copy of the key
# for both this repo and comms-migration) — only uncomment and set a value
# here if you want this repo specifically to use a different key (see
# job_tracker/__init__.py's load order). Leaving this uncommented-but-blank
# would block the shared-file fallback — python-dotenv only skips a key
# that's entirely absent, not one present-but-empty.
# ANTHROPIC_API_KEY=  # pragma: allowlist secret

# Optional: override the model used for the LLM extraction fallback.
# Defaults to claude-haiku-4-5 (fast + cheap) if unset.
# JOB_TRACKER_LLM_MODEL=claude-haiku-4-5
