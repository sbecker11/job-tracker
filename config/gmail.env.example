# Optional: source these paths before running classify_inbox.
# Copy anywhere outside the repo, e.g.:
#   cp config/gmail.env.example ~/.config/job-tracker/env
#   source ~/.config/job-tracker/env
#
# Place the OAuth Desktop client JSON from Google Cloud at:
#   ~/.config/job-tracker/credentials.json
# After first browser login, token.json is created alongside it automatically.

export JOB_TRACKER_GMAIL_CREDENTIALS="$HOME/.config/job-tracker/credentials.json"
export JOB_TRACKER_GMAIL_TOKEN="$HOME/.config/job-tracker/token.json"
